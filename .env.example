# SentinelSupport Production Environment Variables

# ==========================================
# SECURITY
# ==========================================
# The API key required to access the backend. Generate a strong random string.
# On the frontend, set VITE_BACKEND_API_KEY to this same value.
SENTINEL_API_KEY="your-super-secret-api-key"

# Require the API key to be sent in the header (X-API-Key). Must be "true" in production.
SENTINEL_REQUIRE_API_KEY="true"

# ==========================================
# AI INTEGRATION
# ==========================================
# Your Google Gemini API Key
SENTINEL_GEMINI_API_KEY="AIzaSy..."

# ==========================================
# BACKEND BEHAVIOR
# ==========================================
# Set to "production" in production environments
SENTINEL_APP_ENV="production"

# Database URL. The default SQLite configuration for Render/Docker volumes.
SENTINEL_DATABASE_URL="sqlite+aiosqlite:///./data/sentinel_support.db"

# Auto-create the schema on startup. Keep true for SQLite.
SENTINEL_AUTO_CREATE_SCHEMA="true"

# Number of Gunicorn asynchronous workers. 2 is good for 512MB RAM free tiers.
WEB_CONCURRENCY=2

# Logging level (debug, info, warning, error)
LOG_LEVEL="info"

# ==========================================
# FRONTEND CONFIGURATION (Vercel)
# ==========================================
# For Vercel, set these in the Vercel Dashboard Settings -> Environment Variables

# The public URL of your Render backend API (e.g. https://sentinel-backend.onrender.com/api/v1)
VITE_BACKEND_URL="https://your-backend-url.onrender.com"

# The same API key as SENTINEL_API_KEY to authenticate requests from the frontend
VITE_BACKEND_API_KEY="your-super-secret-api-key"
